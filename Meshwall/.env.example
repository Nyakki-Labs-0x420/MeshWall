# MeshWall env config
MESHWALL_CONFIG=/etc/meshwall/meshwall.conf
MESHWALL_LOG_LEVEL=INFO
MESHWALL_GEOIP_DB=/usr/share/GeoIP/GeoLite2-City.mmdb
MESHWALL_DATA_DIR=/var/lib/meshwall
MESHWALL_RUN_DIR=/run/meshwall
DATABASE_URL=sqlite:///instance/meshwall.db
MESHWALL_ENCRYPTION_KEY=change-me-to-a-strong-rando-str
MESHWALL_SALT=change-me-to-a-strong-rando-str
OLLAMA_HOST=http://localhost:11434
